# Copy to .env and fill in. The server loads this automatically (dotenv).

# Port and bind address for the Node server.
# Behind the reverse proxy (Caddy), bind to localhost only.
PORT=8080
HOST=127.0.0.1

# Optional: override where the SQLite database file lives. Defaults to
# <repo root>/MDD_Candy.db, which is fine for local dev and a plain VPS
# install. Only set this in environments where that default path isn't
# writable or persistent (e.g. a container — see docker-compose.yml).
# DB_PATH=/data/MDD_Candy.db
